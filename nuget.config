<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Hermetic NuGet configuration for adp-agent-csharp. The <clear /> entries
    force NuGet to ignore any inherited package sources, credentials, and
    package-source mappings from user-level (%APPDATA%\NuGet\NuGet.Config)
    or machine-level (%ProgramData%\NuGet\Config\*.config) configs. This
    repo depends on EXACTLY two feeds: nuget.org for third-party packages
    and the ai-manifests Gitea feed for Adj/Adp/Acb.Manifest — nothing else
    should ever be consulted during a restore of this solution.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="ai-manifests" value="https://git.marketally.com/api/packages/ai-manifests/nuget/index.json" protocolVersion="3" />
  </packageSources>

  <disabledPackageSources>
    <clear />
  </disabledPackageSources>

  <packageSourceMapping>
    <clear />
    <packageSource key="ai-manifests">
      <package pattern="Adj.Manifest" />
      <package pattern="Adp.Manifest" />
      <package pattern="Acb.Manifest" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
